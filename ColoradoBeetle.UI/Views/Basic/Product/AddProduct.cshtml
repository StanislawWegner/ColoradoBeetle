@using ColoradoBeetle.Application.Products.Commands.AddProduct;
@model AddProductCommand

@{
    ViewData["Tile"] = "Dodawanie produktu";
}
 
<div class="card card-primary card-border-top">

    @using (Html.BeginForm("AddProduct", "Product")) {
        
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.ShoppingListId)

        <div class="card-body">

            <div class="form-group">
                @Html.LabelFor(x => x.Name)
                @Html.TextBoxFor(x => x.Name, new { @class="form-control", 
                    placeholder="Wpisz nazwę productu"})
                @Html.ValidationMessageFor(x => x.Name)
            </div>

            <div class="form-group">
                @Html.LabelFor(x => x.Quantity)
                @Html.TextBoxFor(x => x.Quantity, new { @class="form-control",
                    placeholder="Wpisz nazwę productu"})
                @Html.ValidationMessageFor(x => x.Quantity)
            </div>

            <div class="form-group">
                @Html.LabelFor(x => x.Volume)
                @Html.TextBoxFor(x => x.Name, new { @class="form-control",
            placeholder="Wpisz nazwę productu"})
                @Html.ValidationMessageFor(x => x.Name)
            </div>

            <div class="form-group">
                @Html.LabelFor(x => x.VolumeUnit)
                @Html.TextBoxFor(x => x.Name, new { @class="form-control",
                    placeholder="Wpisz nazwę productu"})
                @Html.ValidationMessageFor(x => x.Name)
            </div>

            <div class="form-group">
                @Html.LabelFor(x => x.Weight)
                @Html.TextBoxFor(x => x.Name, new { @class="form-control",
                placeholder="Wpisz nazwę productu"})
                @Html.ValidationMessageFor(x => x.Name)
            </div>

            <div class="form-group">
                @Html.LabelFor(x => x.WeightUnit)
                @Html.TextBoxFor(x => x.Name, new { @class="form-control",
                placeholder="Wpisz nazwę productu"})
                @Html.ValidationMessageFor(x => x.Name)
            </div>
        </div>
        
        <div class="card-footer">
            <button type="submit" class="btn btn-primary btn-lg">
                <i class="fas fa-solid fa-circle-check"></i>Zapisz
            </button>
        </div>




    }
</div>

@section Scripts{
    <partial name="Scripts/_ValidationScriptsPartial" />
}